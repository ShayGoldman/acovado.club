{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["modules/**"],
  "tasks": {
    "build": {
      "cache": true,
      "persistent": false,
      "inputs": ["$TURBO_DEFAULT", ".env*"],
      "outputs": ["dist/**"],
      "dependsOn": []
    },
    "test": {
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": false
    },
    "lint": {},
    "format": {},
    "start": {
      "cache": false,
      "persistent": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^typecheck"]
    },
    "clean": {
      "cache": false
    }
  }
}
