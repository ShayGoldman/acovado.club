{
  "name": "@repo",
  "description": "",
  "private": true,
  "packageManager": "bun@1.1.36",
  "workspaces": ["config/*", "infra/*", "modules/*", "apps/*", "clients/*", "tests/*"],
  "scripts": {
    "dev:apps": "bunx turbo run dev --filter='./apps/*'",
    "build": "bunx turbo run build",
    "clean": "bunx turbo run clean",
    "format": "bunx biome format --write .",
    "lint": "bunx biome lint --write .",
    "check": "bunx biome check --write .",
    "test": "bunx turbo run test",
    "commit": "bunx cz",
    "prepare": "bunx husky",
    "agents:stitch": "bun docs/paperclip-agents/scripts/stitch.ts",
    "agents:stitch:check": "bun docs/paperclip-agents/scripts/stitch.ts --check",
    "agents:sync": "bun docs/paperclip-agents/scripts/sync.ts",
    "changeset": "bunx changeset",
    "changeset:version": "bunx changeset version",
    "changeset:publish": "bunx changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@config/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.6.3"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
