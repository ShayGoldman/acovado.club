{
  "name": "@modules/db",
  "private": true,
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "bun@1.1.36",
  "scripts": {
    "build:code": "bun build src/index.ts --outdir dist --target bun",
    "build:declarations": "bunx tsup src/index.ts --dts-only --out-dir dist --format esm",
    "build:migrations": "drizzle-kit generate",
    "build": "bun run build:code && bun run build:declarations && bun run build:migrations",
    "seed": "bun src/seed.ts",
    "dev": "bun run build:code --watch & bun run build:declarations --watch",
    "clean": "rm -rf .turbo && rm -rf dist && rm -rf node_modules",
    "typecheck": "bun tsc --noEmit",
    "lint": "bunx biome lint --write .",
    "format": "bunx biome format --write .",
    "check": "bunx biome check --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modules/logger": "workspace:*",
    "@modules/tracing": "workspace:*",
    "bluebird": "^3.7.2",
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.5.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@config/tsconfig": "workspace:*",
    "@config/typescript": "workspace:*",
    "@types/bluebird": "^3.5.42",
    "drizzle-kit": "^0.28.1",
    "drizzle-seed": "^0.1.3",
    "lodash": "^4.17.21",
    "tsup": "^8.3.5",
    "type-fest": "^4.30.1"
  }
}
