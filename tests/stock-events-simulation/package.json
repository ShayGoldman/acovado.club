{
  "name": "@tests/stock-events-simulation",
  "private": true,
  "description": "CLI tool to simulate stock market signal events by publishing them to RabbitMQ.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "bun@1.1.36",
  "scripts": {
    "start": "bun dist/index.js --",
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run build --watch",
    "clean": "rm -rf .turbo && rm -rf dist && rm -rf node_modules",
    "typecheck": "bun tsc --noEmit",
    "lint": "bunx biome lint --write .",
    "format": "bunx biome format --write .",
    "check": "bunx biome check --write ."
  },
  "keywords": ["cli", "simulation", "stock-market"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modules/db": "workspace:*",
    "@modules/logger": "workspace:*",
    "@modules/events": "workspace:*",
    "@modules/tracing": "workspace:*",
    "commander": "^11.1.0",
    "date-fns": "^2.30.0",
    "inquirer": "^9.3.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@config/tsconfig": "workspace:*",
    "@config/typescript": "workspace:*"
  }
}
